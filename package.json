{
    "name": "tauri-app",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "compile-scripts": "tsc ./scripts/*.ts --target esnext --module nodenext --allowSyntheticDefaultImports --outdir ./scripts/dist",
        "build": "tsc",
        "blob": "npm-run-all build && rm -f payload.bin && node scripts/dist/generateBlob.js",
        "build-sea:linux": "npm-run-all blob && ./sea/scripts/build.sh payload.bin",
        "publish:linux": "npm-run-all build-sea:linux && mkdir -p publish && cp sea/build/out publish/installer",
        "dev": "qode dist/bundled.js"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@nodegui/nodegui": "^0.73.0",
        "mongodb": "^7.0.0"
    },
    "devDependencies": {
        "@nodegui/packer": "^1.5.0",
        "@nodegui/qode": "^18.12.1",
        "@types/node": "^25.0.9",
        "esbuild": "^0.27.2",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.9.3"
    }
}
